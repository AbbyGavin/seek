# SEEK Health Extension Vocabulary
# URI:     https://seek4science.org/vocab/seekh#
# Prefix:  seekh:
#
# This namespace is a fallback extension for SEEK extended metadata attributes
# that have no mapping to a standard vocabulary (DCAT-AP, HealthDCAT-AP, DPV,
# Dublin Core, etc.).
#
# Terms are auto-derived at RDF generation time from the ExtendedMetadataAttribute
# title via parameterize(separator: '_'). For example, an attribute titled
# "population coverage" with no pid emits as seekh:population_coverage.
#
# Terms in this namespace are considered UNSTABLE. Assign a proper pid to any
# ExtendedMetadataAttribute you want stable, interoperable RDF output for.

@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix seekh:  <https://seek4science.org/vocab/seekh#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

<https://seek4science.org/vocab/seekh#>
    a owl:Ontology ;
    rdfs:label "SEEK Health Extension Vocabulary"@en ;
    rdfs:comment
        "Fallback namespace for SEEK extended metadata fields that have no mapping to a standard vocabulary. Terms are auto-generated from attribute titles and should be replaced with standard PIDs wherever possible."@en ;
    dct:creator <https://fairdomhub.org/people/1> ;
    dct:publisher <https://fairdomhub.org> ;
    owl:versionInfo "0.1.0" .
