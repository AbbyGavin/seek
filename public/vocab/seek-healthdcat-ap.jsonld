{
  "@context": {
    "dcat": "http://www.w3.org/ns/dcat#",
    "dct": "http://purl.org/dc/terms/",
    "healthdcatap": "http://healthdataportal.eu/ns/health#",
    "dpv": "https://w3id.org/dpv#",
    "seekh": "https://seek4science.org/vocab/seekh#",
    "jerm": "http://jermontology.org/ontology/JERMOntology#",
    "foaf": "http://xmlns.com/foaf/0.1/",
    "vcard": "http://www.w3.org/2006/vcard/ns#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "sh": "http://www.w3.org/ns/shacl#",

    "healthdcatap:healthCategory":         { "@type": "@id" },
    "healthdcatap:healthTheme":            { "@type": "@id" },
    "healthdcatap:hasCodingSystem":        { "@type": "@id" },
    "healthdcatap:publisherType":          { "@type": "@id" },
    "healthdcatap:minTypicalAge":          { "@type": "xsd:integer" },
    "healthdcatap:maxTypicalAge":          { "@type": "xsd:integer" },
    "healthdcatap:numberOfRecords":        { "@type": "xsd:nonNegativeInteger" },
    "healthdcatap:numberOfUniqueIndividuals": { "@type": "xsd:nonNegativeInteger" },
    "healthdcatap:trusteddataholder":      { "@type": "xsd:boolean" },

    "dpv:hasPersonalData":                 { "@type": "@id" },

    "dct:license":                         { "@type": "@id" },
    "dct:accessRights":                    { "@type": "@id" },
    "dct:publisher":                       { "@type": "@id" },
    "dct:creator":                         { "@type": "@id" },
    "dct:language":                        { "@type": "@id" },
    "dct:spatial":                         { "@type": "@id" },
    "dct:conformsTo":                      { "@type": "@id" },
    "dct:issued":                          { "@type": "xsd:date" },
    "dct:modified":                        { "@type": "xsd:dateTime" },
    "dct:created":                         { "@type": "xsd:dateTime" },

    "dcat:accessURL":                      { "@type": "@id" },
    "dcat:downloadURL":                    { "@type": "@id" },
    "dcat:byteSize":                       { "@type": "xsd:decimal" }
  }
}
