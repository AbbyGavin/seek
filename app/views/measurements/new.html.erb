<h1>New <%= t('measurement') %></h1>

<%= form_for @measurement do |f| %>
    <div class="form-group">
      <%= f.error_messages %>

      <div class="form-group">
        <label class="required">Title</label>
        <%= f.text_field :title, :class=>"form-control" -%>
      </div>

      <div class="form-group">
        <label>Description</label>
        <%= f.text_area :description, :class=>"form-control rich-text-edit" -%>
      </div>

      <%= render :partial => "projects/project_selector", :locals => { :resource => @measurement } %>

      <% if show_form_manage_specific_attributes? && @measurement.can_manage?(current_user) %>
        <%= render partial: 'assets/manage_specific_attributes', locals: { f: f, sharing_enable: true, creators_enable: false, sharing_link: false } %>
      <% end %>

      <div class="form-group">
        <%= f.submit 'Create', :class => 'btn btn-primary' %>
        <%= link_to 'Cancel', measurements_path, :class => 'btn btn-default' %>
      </div>
    </div>

<% end -%>

